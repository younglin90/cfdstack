#!/usr/bin/env bash
# cfdstack setup — register CFD skills with Claude Code
set -e

CFDSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
CLAUDE_SKILLS_DIR="$HOME/.claude/skills"

SKILLS=(cfd-new cfd-check cfd-run cfd-post cfd-debug cfd-validate cfd-report cfd-paper-to-code cfd-vv cfd-debug-adv cfd-flux cfd-reconstruction cfd-time-integration cfd-implicit cfd-euler cfd-ns cfd-turbulence)

echo "Installing cfdstack skills..."

# Create skills directory if it doesn't exist
mkdir -p "$CLAUDE_SKILLS_DIR"

# Symlink cfdstack root (for the meta-skill /cfdstack)
if [ -L "$CLAUDE_SKILLS_DIR/cfdstack" ] || [ -d "$CLAUDE_SKILLS_DIR/cfdstack" ]; then
  rm -rf "$CLAUDE_SKILLS_DIR/cfdstack"
fi
ln -snf "$CFDSTACK_DIR" "$CLAUDE_SKILLS_DIR/cfdstack"

# Symlink each individual skill directory
for skill in "${SKILLS[@]}"; do
  # Skip if skill directory doesn't exist yet (will be created by cfd-skill-forge)
  if [ ! -d "$CFDSTACK_DIR/$skill" ]; then
    echo "  - /$skill (not yet created)"
    continue
  fi
  target="$CLAUDE_SKILLS_DIR/$skill"
  if [ -L "$target" ] || [ -d "$target" ]; then
    rm -rf "$target"
  fi
  ln -snf "$CFDSTACK_DIR/$skill" "$target"
  echo "  ✓ /$skill"
done

echo ""
echo "cfdstack ready. (17 skills)"
echo ""
echo "Simulation:  /cfd-new /cfd-check /cfd-run /cfd-post /cfd-debug /cfd-validate /cfd-report"
echo "Solver dev:  /cfd-paper-to-code /cfd-vv /cfd-debug-adv /cfd-flux /cfd-reconstruction"
echo "             /cfd-time-integration /cfd-implicit /cfd-euler /cfd-ns /cfd-turbulence"
echo "Overview:    /cfdstack"
